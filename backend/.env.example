DB_NAME=urbanmindv2
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432

CRIME_API_URL=https://data.cityofchicago.org/resource/ijzp-q8t2.json
REQUESTS_311_API_URL=https://data.cityofchicago.org/resource/v6vf-nfxy.json
TRAFFIC_API_URL=https://data.cityofchicago.org/resource/sxs8-h27x.json
BUSINESS_API_URL=https://data.cityofchicago.org/resource/r5kz-chrr.json
PERMITS_API_URL=https://data.cityofchicago.org/resource/ydr8-5enu.json
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=UrbanMindV2/1.0
SOCRATA_APP_TOKEN=

GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=20
CORS_ORIGINS=*

# Pipeline scheduling and model-promotion gates
PIPELINE_RETRAIN_INTERVAL_DAYS=7
PIPELINE_INGEST_INTERVAL_HOURS=24
PIPELINE_RUN_WITH_API=true
PIPELINE_API_START_DELAY_SECONDS=10
PIPELINE_API_INTERVAL_HOURS=24
PIPELINE_MAX_CRIME_AGE_HOURS=48
PIPELINE_MIN_MAE_IMPROVEMENT=0.03
PIPELINE_MIN_AP_LIFT=3.0
PIPELINE_MIN_TOP1_RECALL=0.10
PIPELINE_MAX_TOTAL_BIAS=0.10
PIPELINE_DATA_TIMEZONE=America/Chicago
